    <preConditions onFail="MARK_RAN">
      <not>
        <foreignKeyConstraintExists foreignKeyName="fk_instance_id" foreignKeyTableName="instance_statistical_code"/>
      </not>
    </preConditions>
    <comment>Add FK from instance_statistical_code.instance_id to instance.id with cascade delete</comment>

    <addForeignKeyConstraint
      constraintName="fk_instance_id"
      baseTableName="instance_statistical_code"
      baseColumnNames="instance_id"
      referencedTableName="instance"
      referencedColumnNames="id"
      onDelete="CASCADE"/>
  </changeSet>

